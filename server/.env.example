# ─────────────────────────────────────────────────────────────────────────────
# Paellas Masía — Backend environment variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3001
NODE_ENV=development

# ─── Redsys / Santander TPV ──────────────────────────────────────────────────

# Set to "true" to use the Redsys TEST endpoint, "false" for production
REDSYS_TEST_MODE=false

# Your 9-digit FUC / Merchant Code (provided by your bank)
REDSYS_MERCHANT_CODE=48427249

# Terminal number (usually 1)
REDSYS_TERMINAL=1

# Currency code: 978 = EUR
REDSYS_CURRENCY=978

# Transaction type: 0 = standard charge
REDSYS_TRANSACTION_TYPE=0

# SHA-256 Base64 secret key — obtained from the Redsys back-office
# Test key (sandbox):
REDSYS_SECRET_KEY=sq7HjrUOBfKmC576ILgskD5srU870gJ7

# Public HTTPS URL where Redsys will POST the payment notification (webhook)
# Must be reachable from the internet (not localhost in production)
REDSYS_NOTIFICATION_URL=https://yoursite.com/api/payment/webhook

# ─── CORS ────────────────────────────────────────────────────────────────────

# Frontend dev server URL (for CORS whitelisting in development)
FRONTEND_URL=http://localhost:5173
